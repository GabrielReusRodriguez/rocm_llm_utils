# Config general
##########################################################
# Para forzar la ejecución de la arquitectura RDNA4
HSA_OVERRIDE_GFX_VERSION=12.0.0
#: ${LLAMA_CFG_AMDGPU_TARGETS:=gfx1200}

#Config GPU
##########################################################
# Número de capas que ejecutará la GPU 
LLAMA_GPU_CFG_NUM_GPU_LAYERS=99
# Forzamos el uso de memoria Pinned para OCulink.
GGML_HIP_ALLOC_GRAPH=1
# Aquí indicamos que ids de gpu es la que queremos que vea, podemos ver el listado de gpus con rocm-smi y rocminfo (chip ID)
HIP_VISIBLE_DEVICES=0

#Config CPU
##########################################################
# Llama, Numero de threads que usará la CPU en la llm
LLAMA_CPU_CFG_NUM_THREADS=12

